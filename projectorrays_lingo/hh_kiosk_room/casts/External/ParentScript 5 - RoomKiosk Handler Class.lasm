on handle_flatcreated me, tMsg
  [  0] getparam 1 .............................. <tMsg>
  [  2] getchainedprop 193 ...................... <tMsg.content>
  [  4] pushsymb 194 ............................ <#line>
  [  6] pushint8 1 .............................. <1>
  [  8] pusharglist 3 ........................... <tMsg.content, #line, 1>
  [ 10] objcall 195 ............................. <tMsg.content.line[1]>
  [ 12] pushsymb 196 ............................ <#word>
  [ 14] pushint8 1 .............................. <1>
  [ 16] pusharglist 3 ........................... <tMsg.content.line[1], #word, 1>
  [ 18] objcall 83 .............................. <tMsg.content.line[1].word[1]>
  [ 20] setlocal 0 .............................. tID = tMsg.content.line[1].word[1]
  [ 22] getparam 1 .............................. <tMsg>
  [ 24] getchainedprop 193 ...................... <tMsg.content>
  [ 26] pushsymb 194 ............................ <#line>
  [ 28] pushint8 2 .............................. <2>
  [ 30] pusharglist 3 ........................... <tMsg.content, #line, 2>
  [ 32] objcall 83 .............................. <tMsg.content.line[2]>
  [ 34] setlocal 1 .............................. tName = tMsg.content.line[2]
  [ 36] getparam 0 .............................. <me>
  [ 38] pusharglist 1 ........................... <me>
  [ 40] objcall 15 .............................. <me.getInterface()>
  [ 42] getlocal 1 .............................. <tName>
  [ 44] getlocal 0 .............................. <tID>
  [ 46] pusharglistnoret 3 ...................... <me.getInterface(), tName, tID>
  [ 48] objcall 40 .............................. me.getInterface().flatcreated(tName, tID)
  [ 50] ret
end

on handle_error me, tMsg
  [  0] getparam 1 .............................. <tMsg>
  [  2] getobjprop 193 .......................... <tMsg.content>
  [  4] setlocal 0 .............................. tErr = tMsg.content
  [  6] getlocal 0 .............................. <tErr>
  [  8] peek 0 .................................. case tErr of
  [ 10] pushcons 2 .............................. <"Error creating a private room">
  [ 12] eq
  [ 13] jmpifz [ 49] ............................ (case) "Error creating a private room":
  [ 16] pushsymb 162 ............................ <#alert>
  [ 18] pushsymb 163 ............................ <#Msg>
  [ 20] pushcons 3 .............................. <"roomatic_create_error">
  [ 22] pusharglist 1 ........................... <"roomatic_create_error">
  [ 24] extcall 88 .............................. <getText("roomatic_create_error")>
  [ 26] pusharglist 2 ........................... <[#Msg: getText("roomatic_create_error")]>
  [ 28] pushproplist ............................ <[#Msg: getText("roomatic_create_error")]>
  [ 29] pusharglistnoret 2 ...................... <#alert, [#Msg: getText("roomatic_create_error")]>
  [ 31] extcall 35 .............................. executeMessage(#alert, [#Msg: getText("roomatic_create_error")])
  [ 33] pop 1
  [ 35] getparam 0 .............................. <me>
  [ 37] pusharglist 1 ........................... <me>
  [ 39] objcall 15 .............................. <me.getInterface()>
  [ 41] pusharglist 1 ........................... <me.getInterface()>
  [ 43] objcall 2 ............................... <me.getInterface().showHideRoomKiosk()>
  [ 45] pusharglistnoret 1 ...................... <me.getInterface().showHideRoomKiosk()>
  [ 47] extcall 12 .............................. return me.getInterface().showHideRoomKiosk()
  [ 49] pop 1
  [ 51] pushint8 1 .............................. <1>
  [ 53] pusharglistnoret 1 ...................... <1>
  [ 55] extcall 12 .............................. return 1
  [ 57] ret
end

on handle_webShortcut me, tMsg
  [  0] getparam 1 .............................. <tMsg>
  [  2] pushsymb 224 ............................ <#connection>
  [  4] pusharglist 2 ........................... <tMsg, #connection>
  [  6] objcall 225 ............................. <tMsg.getaProp(#connection)>
  [  8] setlocal 0 .............................. tConn = tMsg.getaProp(#connection)
  [ 10] getlocal 0 .............................. <tConn>
  [ 12] not ..................................... <not tConn>
  [ 13] jmpifz [ 32] ............................ if not tConn then
  [ 16] getparam 0 .............................. <me>
  [ 18] pushcons 4 .............................. <"Connection not found.">
  [ 20] pushsymb 236 ............................ <#handle_webShortcut>
  [ 22] pushsymb 24 ............................. <#major>
  [ 24] pusharglist 4 ........................... <me, "Connection not found.", #handle_webShortcut, #major>
  [ 26] extcall 23 .............................. <error(me, "Connection not found.", #handle_webShortcut, #major)>
  [ 28] pusharglistnoret 1 ...................... <error(me, "Connection not found.", #handle_webShortcut, #major)>
  [ 30] extcall 12 .............................. return error(me, "Connection not found.", #handle_webShortcut, #major)
  [ 32] getlocal 0 .............................. <tConn>
  [ 34] pusharglist 1 ........................... <tConn>
  [ 36] objcall 227 ............................. <tConn.GetIntFrom()>
  [ 38] setlocal 1 .............................. tRequestId = tConn.GetIntFrom()
  [ 40] getlocal 1 .............................. <tRequestId>
  [ 42] pushint8 1 .............................. <1>
  [ 44] eq ...................................... <tRequestId = 1>
  [ 45] jmpifz [ 60] ............................ if tRequestId = 1 then
  [ 48] pushsymb 29 ............................. <#open_roomkiosk>
  [ 50] pusharglistnoret 1 ...................... <#open_roomkiosk>
  [ 52] extcall 35 .............................. executeMessage(#open_roomkiosk)
  [ 54] pushint8 1 .............................. <1>
  [ 56] pusharglistnoret 1 ...................... <1>
  [ 58] extcall 12 .............................. return 1
  [ 60] pushzero ................................ <0>
  [ 61] pusharglistnoret 1 ...................... <0>
  [ 63] extcall 12 .............................. return 0
  [ 65] ret
end
