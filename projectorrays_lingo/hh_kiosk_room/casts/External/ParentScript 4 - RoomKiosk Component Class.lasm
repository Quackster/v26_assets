  [ 72] getparam 0 .............................. <me>
  [ 74] pushcons 8 .............................. <"Unknown state:">
  [ 76] getparam 1 .............................. <tstate>
  [ 78] joinpadstr .............................. <"Unknown state:" && tstate>
  [ 79] pushsymb 6 .............................. <#updateState>
  [ 81] pushsymb 30 ............................. <#minor>
  [ 83] pusharglist 4 ........................... <me, "Unknown state:" && tstate, #updateState, #minor>
