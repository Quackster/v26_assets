  [ 32] jmp [ 91]
  [ 35] peek 0
  [ 37] pushcons 0 .............................. <"start">
  [ 39] eq
  [ 40] jmpifz [ 70] ............................ (case) "start":
  [ 43] getparam 1 .............................. <tstate>
  [ 45] setprop 28 .............................. pState = tstate
  [ 47] pop 1
  [ 49] pushsymb 29 ............................. <#open_roomkiosk>
  [ 51] getparam 0 .............................. <me>
  [ 53] pusharglist 1 ........................... <me>
  [ 55] objcall 11 .............................. <me.getID()>
