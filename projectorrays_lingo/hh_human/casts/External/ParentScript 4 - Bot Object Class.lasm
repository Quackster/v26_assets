on getInfo me
  [  0] getparam 0 .............................. <me>
  [  2] getobjprop 118 .......................... <me.pInfoStruct>
  [  4] pusharglistnoret 1 ...................... <me.pInfoStruct>
  [  6] extcall 156 ............................. return me.pInfoStruct
  [  8] ret
end

on action_taked me
  [  0] getparam 0 .............................. <me>
  [  2] pushint8 1 .............................. <1>
  [  4] setobjprop 100 .......................... me.pCarrying = 1
  [  6] getparam 0 .............................. <me>
  [  8] getparam 0 .............................. <me>
  [ 10] pushsymb 142 ............................ <#pPartListSubSet>
  [ 12] pushcons 0 .............................. <"handRight">
  [ 14] pusharglist 3 ........................... <me, #pPartListSubSet, "handRight">
  [ 16] objcall 249 ............................. <me.pPartListSubSet["handRight"]>
  [ 18] pushcons 1 .............................. <"crr">
  [ 20] pusharglistnoret 3 ...................... <me, me.pPartListSubSet["handRight"], "crr">
  [ 22] objcall 48 .............................. me.definePartListAction(me.pPartListSubSet["handRight"], "crr")
  [ 24] ret
end

on action_gived me
  [  0] getparam 0 .............................. <me>
  [  2] pushint8 1 .............................. <1>
  [  4] setobjprop 100 .......................... me.pCarrying = 1
  [  6] getparam 0 .............................. <me>
  [  8] getparam 0 .............................. <me>
  [ 10] pushsymb 142 ............................ <#pPartListSubSet>
  [ 12] pushcons 0 .............................. <"handRight">
  [ 14] pusharglist 3 ........................... <me, #pPartListSubSet, "handRight">
  [ 16] objcall 249 ............................. <me.pPartListSubSet["handRight"]>
  [ 18] pushcons 1 .............................. <"crr">
  [ 20] pusharglistnoret 3 ...................... <me, me.pPartListSubSet["handRight"], "crr">
  [ 22] objcall 48 .............................. me.definePartListAction(me.pPartListSubSet["handRight"], "crr")
  [ 24] ret
end

on getClass me
  [  0] pushcons 2 .............................. <"bot">
  [  2] pusharglistnoret 1 ...................... <"bot">
  [  4] extcall 156 ............................. return "bot"
  [  6] ret
end
