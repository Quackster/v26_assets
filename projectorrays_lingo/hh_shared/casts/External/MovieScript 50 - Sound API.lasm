end

on getSoundManager
  [  0] pusharglist 0 ........................... <>
  [  2] extcall 513 ............................. <getObjectManager()>
  [  5] setlocal 0 .............................. tMgr = getObjectManager()
  [  7] getlocal 0 .............................. <tMgr>
  [  9] pushsymb 510 ............................ <#sound_manager>
  [ 12] pusharglist 2 ........................... <tMgr, #sound_manager>
  [ 14] objcall 514 ............................. <tMgr.managerExists(#sound_manager)>
  [ 17] not ..................................... <not tMgr.managerExists(#sound_manager)>
  [ 18] jmpifz [ 29] ............................ if not tMgr.managerExists(#sound_manager) then
  [ 21] pusharglist 0 ........................... <>
  [ 23] localcall 0 ............................. <constructSoundManager()>
  [ 25] pusharglistnoret 1 ...................... <constructSoundManager()>
  [ 27] extcall 18 .............................. return constructSoundManager()
  [ 29] getlocal 0 .............................. <tMgr>
  [ 31] pushsymb 510 ............................ <#sound_manager>
  [ 34] pusharglist 2 ........................... <tMgr, #sound_manager>
  [ 36] objcall 515 ............................. <tMgr.getManager(#sound_manager)>
  [ 39] pusharglistnoret 1 ...................... <tMgr.getManager(#sound_manager)>
  [ 41] extcall 18 .............................. return tMgr.getManager(#sound_manager)
  [ 43] ret
end

