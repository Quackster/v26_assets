  [ 91] joinpadstr .............................. <"* Channel" && pChannelNum & " - Playtime left:" && me.getTimeRemaining() && "Now playing:" && tName && "Queue:">
  [ 92] getlocal 0 .............................. <tChannel>
  [ 94] pusharglist 1 ........................... <tChannel>
  [ 96] objcall 570 ............................. <tChannel.getPlaylist()>
  [ 99] getobjprop 125 .......................... <tChannel.getPlaylist().count>
  [101] joinpadstr .............................. <"* Channel" && pChannelNum & " - Playtime left:" && me.getTimeRemaining() && "Now playing:" && tName && "Queue:" && tChannel.getPlaylist().count>
  [102] pusharglistnoret 1 ...................... <"* Channel" && pChannelNum & " - Playtime left:" && me.getTimeRemaining() && "Now playing:" && tName && "Queue:" && tChannel.getPlaylist().count>
  [104] extcall 383 ............................. put "* Channel" && pChannelNum & " - Playtime left:" && me.getTimeRemaining() && "Now playing:" && tName && "Queue:" && tChannel.getPlaylist().count
  [107] ret
end
