property pSignSpr, pSignMem

on construct me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglist 1 ........................... <me>
  [  4] objcall 39 .............................. <me.getID()>
  [  6] pusharglist 1 ........................... <me.getID()>
  [  8] extcall 304 ............................. <reserveSprite(me.getID())>
  [ 11] pusharglist 1 ........................... <reserveSprite(me.getID())>
  [ 13] extcall 303 ............................. <sprite(reserveSprite(me.getID()))>
  [ 16] setprop 302 ............................. pSignSpr = sprite(reserveSprite(me.getID()))
  [ 19] pushint8 1 .............................. <1>
  [ 21] pusharglistnoret 1 ...................... <1>
  [ 23] extcall 41 .............................. return 1
  [ 25] ret
end

on deconstruct me
  [  0] getprop 302 ............................. <pSignSpr>
  [  3] getobjprop 306 .......................... <pSignSpr.spriteNum>
  [  6] pusharglistnoret 1 ...................... <pSignSpr.spriteNum>
  [  8] extcall 305 ............................. releaseSprite(pSignSpr.spriteNum)
  [ 11] pusharglist 0 ........................... <>
  [ 13] extcall 243 ............................. <VOID>
  [ 15] setprop 302 ............................. pSignSpr = VOID
  [ 18] pushint8 1 .............................. <1>
  [ 20] pusharglistnoret 1 ...................... <1>
  [ 22] extcall 41 .............................. return 1
  [ 24] ret
end

on Refresh me
  [  0] getprop 302 ............................. <pSignSpr>
  [  3] pushzero ................................ <0>
  [  4] setobjprop 307 .......................... pSignSpr.visible = 0
  [  7] ret
end

