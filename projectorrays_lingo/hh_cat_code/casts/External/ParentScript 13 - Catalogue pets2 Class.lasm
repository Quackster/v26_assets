on construct me
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglistnoret 1 ...................... <1>
  [  4] extcall 27 .............................. return 1
  [  6] ret
end

on deconstruct me
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglistnoret 1 ...................... <1>
  [  4] extcall 27 .............................. return 1
  [  6] ret
end

on eventProc me, tEvent, tSprID, tProp
  [  0] getparam 1 .............................. <tEvent>
  [  2] pushsymb 148 ............................ <#mouseUp>
  [  4] eq ...................................... <tEvent = #mouseUp>
  [  5] jmpifz [ 43] ............................ if tEvent = #mouseUp then
  [  8] getparam 2 .............................. <tSprID>
  [ 10] pushcons 0 .............................. <"ctlg_text_3">
  [ 12] eq ...................................... <tSprID = "ctlg_text_3">
  [ 13] jmpifz [ 43] ............................ if tSprID = "ctlg_text_3" then
  [ 16] pushcons 1 .............................. <"url_pets">
  [ 18] pusharglist 1 ........................... <"url_pets">
  [ 20] extcall 100 ............................. <getText("url_pets")>
  [ 22] setlocal 0 .............................. tURL = getText("url_pets")
  [ 24] pushsymb 406 ............................ <#externalLinkClick>
  [ 27] getmovieprop 402 ........................ <the mouseLoc>
  [ 30] pusharglistnoret 2 ...................... <#externalLinkClick, the mouseLoc>
  [ 32] extcall 225 ............................. executeMessage(#externalLinkClick, the mouseLoc)
  [ 34] getlocal 0 .............................. <tURL>
  [ 36] pushcons 2 .............................. <"_new">
  [ 38] pusharglistnoret 2 ...................... <tURL, "_new">
  [ 40] extcall 405 ............................. openNetPage(tURL, "_new")
  [ 43] pushzero ................................ <0>
  [ 44] pusharglistnoret 1 ...................... <0>
  [ 46] extcall 27 .............................. return 0
  [ 48] ret
end
