on handleClick me, tEvent, tSprID, tProp
  [  0] getparam 1 .............................. <tEvent>
  [  2] pushsymb 154 ............................ <#mouseUp>
  [  4] eq ...................................... <tEvent = #mouseUp>
  [  5] jmpifz [ 46] ............................ if tEvent = #mouseUp then
  [  8] getparam 2 .............................. <tSprID>
  [ 10] peek 0 .................................. case tSprID of
  [ 12] pushcons 0 .............................. <"ctlg_collectibles_link">
  [ 14] eq
  [ 15] jmpifz [ 44] ............................ (case) "ctlg_collectibles_link":
  [ 18] pushsymb 298 ............................ <#externalLinkClick>
  [ 21] getmovieprop 299 ........................ <the mouseLoc>
  [ 24] pusharglistnoret 2 ...................... <#externalLinkClick, the mouseLoc>
  [ 26] extcall 297 ............................. executeMessage(#externalLinkClick, the mouseLoc)
  [ 29] pushcons 1 .............................. <"url_collectables_link">
  [ 31] pusharglist 1 ........................... <"url_collectables_link">
  [ 33] extcall 129 ............................. <getText("url_collectables_link")>
  [ 35] pusharglist 1 ........................... <getText("url_collectables_link")>
  [ 37] extcall 237 ............................. <getPredefinedURL(getText("url_collectables_link"))>
  [ 39] pusharglistnoret 1 ...................... <getPredefinedURL(getText("url_collectables_link"))>
  [ 41] extcall 300 ............................. openNetPage(getPredefinedURL(getText("url_collectables_link")))
  [ 44] pop 1
  [ 46] ret
end
