on construct me
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglistnoret 1 ...................... <1>
  [  4] extcall 30 .............................. return 1
  [  6] ret
end

on deconstruct me
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglistnoret 1 ...................... <1>
  [  4] extcall 30 .............................. return 1
  [  6] ret
end

on define me
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglistnoret 1 ...................... <1>
  [  4] extcall 30 .............................. return 1
  [  6] ret
end

on eventProc me, tEvent, tSprID, tProp
  [  0] getparam 1 .............................. <tEvent>
  [  2] pushsymb 154 ............................ <#mouseUp>
  [  4] eq ...................................... <tEvent = #mouseUp>
  [  5] jmpifz [ 44] ............................ if tEvent = #mouseUp then
  [  8] getparam 2 .............................. <tSprID>
  [ 10] pushcons 0 .............................. <"ctlg_text_3">
  [ 12] eq ...................................... <tSprID = "ctlg_text_3">
  [ 13] jmpifz [ 44] ............................ if tSprID = "ctlg_text_3" then
  [ 16] pushcons 1 .............................. <"url_pets">
  [ 18] pusharglist 1 ........................... <"url_pets">
  [ 20] extcall 129 ............................. <getText("url_pets")>
  [ 22] setlocal 0 .............................. tURL = getText("url_pets")
  [ 24] pushsymb 298 ............................ <#externalLinkClick>
  [ 27] getmovieprop 299 ........................ <the mouseLoc>
  [ 30] pusharglistnoret 2 ...................... <#externalLinkClick, the mouseLoc>
  [ 32] extcall 297 ............................. executeMessage(#externalLinkClick, the mouseLoc)
  [ 35] getlocal 0 .............................. <tURL>
  [ 37] pushcons 2 .............................. <"_new">
  [ 39] pusharglistnoret 2 ...................... <tURL, "_new">
  [ 41] extcall 300 ............................. openNetPage(tURL, "_new")
  [ 44] pushzero ................................ <0>
  [ 45] pusharglistnoret 1 ...................... <0>
  [ 47] extcall 30 .............................. return 0
  [ 49] ret
end
