property pSprite, pOffset, pWaitTrainTimer

on define me, tsprite
  [  0] getparam 1 .............................. <tsprite>
  [  2] setprop 190 ............................. pSprite = tsprite
  [  4] getparam 0 .............................. <me>
  [  6] pusharglistnoret 1 ...................... <me>
  [  8] objcall 231 ............................. me.reset()
  [ 10] ret
end

on reset me
  [  0] pushint8 30 ............................. <30>
  [  2] pusharglist 1 ........................... <30>
  [  4] extcall 213 ............................. <random(30)>
  [  6] pushint8 15 ............................. <15>
  [  8] add ..................................... <random(30) + 15>
  [  9] setlocal 0 .............................. tTrainSpeed = random(30) + 15
  [ 11] getprop 190 ............................. <pSprite>
  [ 13] pushint16 743 ........................... <743>
  [ 16] pushint16 443 ........................... <443>
  [ 19] pusharglist 2 ........................... <743, 443>
  [ 21] extcall 237 ............................. <point(743, 443)>
  [ 23] setobjprop 220 .......................... pSprite.loc = point(743, 443)
  [ 25] pushint8 2 .............................. <2>
  [ 27] inv ..................................... <-2>
  [ 28] pushint8 1 .............................. <1>
  [ 30] inv ..................................... <-1>
  [ 31] pusharglist 2 ........................... <[-2, -1]>
  [ 33] pushlist ................................ <[-2, -1]>
  [ 34] pushint8 2 .............................. <2>
  [ 36] pusharglist 1 ........................... <2>
  [ 38] extcall 213 ............................. <random(2)>
  [ 40] mul ..................................... <[-2, -1] * random(2)>
  [ 41] setprop 232 ............................. pOffset = [-2, -1] * random(2)
  [ 43] pushint16 250 ........................... <250>
  [ 46] pusharglist 1 ........................... <250>
  [ 48] extcall 213 ............................. <random(250)>
  [ 50] setprop 267 ............................. pWaitTrainTimer = random(250)
  [ 53] ret
end

on update me
  [  0] getprop 267 ............................. <pWaitTrainTimer>
  [  3] pushzero ................................ <0>
  [  4] gt ...................................... <pWaitTrainTimer > 0>
  [  5] jmpifz [ 22] ............................ if pWaitTrainTimer > 0 then
  [  8] getprop 267 ............................. <pWaitTrainTimer>
  [ 11] pushint8 1 .............................. <1>
  [ 13] sub ..................................... <pWaitTrainTimer - 1>
  [ 14] setprop 267 ............................. pWaitTrainTimer = pWaitTrainTimer - 1
  [ 17] pushzero ................................ <0>
  [ 18] pusharglistnoret 1 ...................... <0>
  [ 20] extcall 49 .............................. return 0
  [ 22] getprop 190 ............................. <pSprite>
  [ 24] getobjprop 212 .......................... <pSprite.locH>
  [ 26] pushint8 100 ............................ <100>
  [ 28] gt ...................................... <pSprite.locH > 100>
  [ 29] jmpifz [ 46] ............................ if pSprite.locH > 100 then / else
  [ 32] getprop 190 ............................. <pSprite>
  [ 34] getprop 190 ............................. <pSprite>
  [ 36] getobjprop 220 .......................... <pSprite.loc>
  [ 38] getprop 232 ............................. <pOffset>
  [ 40] add ..................................... <pSprite.loc + pOffset>
  [ 41] setobjprop 220 .......................... pSprite.loc = pSprite.loc + pOffset
  [ 43] jmp [ 52]
  [ 46] getparam 0 .............................. <me>
  [ 48] pusharglistnoret 1 ...................... <me>
  [ 50] objcall 231 ............................. me.reset()
  [ 52] ret
end
