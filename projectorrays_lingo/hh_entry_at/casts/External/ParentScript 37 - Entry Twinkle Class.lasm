property pSprite, pRandom, pCount, pAdd, pMyNo

on define me, tsprite, tNo
  [  0] getparam 1 .............................. <tsprite>
  [  2] setprop 7 ............................... pSprite = tsprite
  [  4] getparam 2 .............................. <tNo>
  [  6] setprop 81 .............................. pMyNo = tNo
  [  8] getparam 0 .............................. <me>
  [ 10] pusharglistnoret 1 ...................... <me>
  [ 12] objcall 62 .............................. me.reset()
  [ 14] pushint8 1 .............................. <1>
  [ 16] pusharglistnoret 1 ...................... <1>
  [ 18] extcall 28 .............................. return 1
  [ 20] ret
end

on reset me
  [  0] pushint8 100 ............................ <100>
  [  2] pusharglist 1 ........................... <100>
  [  4] extcall 42 .............................. <random(100)>
  [  6] setprop 83 .............................. pRandom = random(100)
  [  8] getprop 7 ............................... <pSprite>
  [ 10] pushcons 0 .............................. <"twinkle_small">
  [ 12] pusharglist 1 ........................... <"twinkle_small">
  [ 14] extcall 11 .............................. <getmemnum("twinkle_small")>
  [ 16] setobjprop 10 ........................... pSprite.member = getmemnum("twinkle_small")
  [ 18] pushzero ................................ <0>
  [ 19] setprop 84 .............................. pCount = 0
  [ 21] pushint8 15 ............................. <15>
  [ 23] setprop 85 .............................. pAdd = 15
  [ 25] getprop 7 ............................... <pSprite>
  [ 27] pusharglist 1 ........................... <pSprite>
  [ 29] extcall 86 .............................. <sprite(pSprite)>
  [ 31] getprop 84 .............................. <pCount>
  [ 33] setobjprop 79 ........................... sprite(pSprite).blend = pCount
  [ 35] ret
end

on update me
  [  0] getprop 83 .............................. <pRandom>
  [  2] pushint8 1 .............................. <1>
  [  4] eq ...................................... <pRandom = 1>
  [  5] jmpifz [ 89] ............................ if pRandom = 1 then / else
  [  8] getprop 84 .............................. <pCount>
  [ 10] getprop 85 .............................. <pAdd>
  [ 12] add ..................................... <pCount + pAdd>
  [ 13] setprop 84 .............................. pCount = pCount + pAdd
  [ 15] pushint8 1 .............................. <1>
  [ 17] peek 0 .................................. case 1 of
  [ 19] getprop 84 .............................. <pCount>
  [ 21] pushzero ................................ <0>
  [ 22] gteq .................................... <pCount >= 0>
  [ 23] getprop 84 .............................. <pCount>
  [ 25] pushint8 100 ............................ <100>
  [ 27] lteq .................................... <pCount <= 100>
  [ 28] and ..................................... <(pCount >= 0) and (pCount <= 100)>
  [ 29] eq
  [ 30] jmpifz [ 46] ............................ (case) ((pCount >= 0) and (pCount <= 100)):
  [ 33] getprop 7 ............................... <pSprite>
  [ 35] pusharglist 1 ........................... <pSprite>
  [ 37] extcall 86 .............................. <sprite(pSprite)>
  [ 39] getprop 84 .............................. <pCount>
  [ 41] setobjprop 79 ........................... sprite(pSprite).blend = pCount
  [ 43] jmp [ 84]
  [ 46] peek 0
  [ 48] getprop 84 .............................. <pCount>
  [ 50] pushint8 100 ............................ <100>
  [ 52] gt ...................................... <pCount > 100>
  [ 53] eq
  [ 54] jmpifz [ 68] ............................ (case) (pCount > 100):
  [ 57] getprop 85 .............................. <pAdd>
  [ 59] pushint8 1 .............................. <1>
  [ 61] inv ..................................... <-1>
  [ 62] mul ..................................... <pAdd * -1>
  [ 63] setprop 85 .............................. pAdd = pAdd * -1
  [ 65] jmp [ 84]
  [ 68] peek 0
  [ 70] getprop 84 .............................. <pCount>
  [ 72] pushzero ................................ <0>
  [ 73] lt ...................................... <pCount < 0>
  [ 74] eq
  [ 75] jmpifz [ 84] ............................ (case) (pCount < 0):
  [ 78] getparam 0 .............................. <me>
  [ 80] pusharglistnoret 1 ...................... <me>
  [ 82] objcall 62 .............................. me.reset()
  [ 84] pop 1 ................................... end case
  [ 86] jmp [ 95]
  [ 89] getparam 0 .............................. <me>
  [ 91] pusharglistnoret 1 ...................... <me>
  [ 93] objcall 62 .............................. me.reset()
  [ 95] ret
end
