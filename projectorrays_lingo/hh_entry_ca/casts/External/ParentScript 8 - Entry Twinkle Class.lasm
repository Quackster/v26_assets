property pSprite, pRandom, pFrameCount, pCount

on define me, tsprite
  [  0] getparam 1 .............................. <tsprite>
  [  2] setprop 5 ............................... pSprite = tsprite
  [  4] getparam 0 .............................. <me>
  [  6] pusharglistnoret 1 ...................... <me>
  [  8] objcall 1 ............................... me.reset()
  [ 10] pushint8 1 .............................. <1>
  [ 12] pusharglistnoret 1 ...................... <1>
  [ 14] extcall 9 ............................... return 1
  [ 16] ret
end

on reset me
  [  0] pushint8 90 ............................. <90>
  [  2] pusharglist 1 ........................... <90>
  [  4] extcall 14 .............................. <random(90)>
  [  6] pushint8 18 ............................. <18>
  [  8] add ..................................... <random(90) + 18>
  [  9] setprop 74 .............................. pRandom = random(90) + 18
  [ 11] getprop 5 ............................... <pSprite>
  [ 13] pushcons 0 .............................. <"twinkle_0">
  [ 15] pusharglist 1 ........................... <"twinkle_0">
  [ 17] extcall 16 .............................. <getmemnum("twinkle_0")>
  [ 19] setobjprop 21 ........................... pSprite.member = getmemnum("twinkle_0")
  [ 21] pushint8 1 .............................. <1>
  [ 23] setprop 75 .............................. pFrameCount = 1
  [ 25] pushzero ................................ <0>
  [ 26] setprop 76 .............................. pCount = 0
  [ 28] ret
end

on update me
  [  0] pushzero ................................ <0>
  [  1] pushint8 1 .............................. <1>
  [  3] pushint8 2 .............................. <2>
  [  5] pushint8 3 .............................. <3>
  [  7] pushint8 4 .............................. <4>
  [  9] pushint8 5 .............................. <5>
  [ 11] pushint8 6 .............................. <6>
  [ 13] pushint8 7 .............................. <7>
  [ 15] pusharglist 8 ........................... <[0, 1, 2, 3, 4, 5, 6, 7]>
  [ 17] pushlist ................................ <[0, 1, 2, 3, 4, 5, 6, 7]>
  [ 18] setlocal 0 .............................. tFrameList = [0, 1, 2, 3, 4, 5, 6, 7]
  [ 20] getprop 76 .............................. <pCount>
  [ 22] pushint8 1 .............................. <1>
  [ 24] add ..................................... <pCount + 1>
  [ 25] setprop 76 .............................. pCount = pCount + 1
  [ 27] pushint8 1 .............................. <1>
  [ 29] peek 0 .................................. case 1 of
  [ 31] getprop 76 .............................. <pCount>
  [ 33] pushzero ................................ <0>
  [ 34] gt ...................................... <pCount > 0>
  [ 35] getprop 76 .............................. <pCount>
  [ 37] pushint8 15 ............................. <15>
  [ 39] lteq .................................... <pCount <= 15>
  [ 40] and ..................................... <(pCount > 0) and (pCount <= 15)>
  [ 41] eq
  [ 42] jmpifz [ 86] ............................ (case) ((pCount > 0) and (pCount <= 15)):
  [ 45] getprop 76 .............................. <pCount>
  [ 47] pushint8 2 .............................. <2>
  [ 49] mod ..................................... <pCount mod 2>
  [ 50] jmpifz [ 83] ............................ if pCount mod 2 then
  [ 53] pushcons 1 .............................. <"twinkle_">
  [ 55] getlocal 0 .............................. <tFrameList>
  [ 57] getprop 75 .............................. <pFrameCount>
  [ 59] pusharglist 2 ........................... <tFrameList, pFrameCount>
  [ 61] objcall 15 .............................. <tFrameList[pFrameCount]>
  [ 63] joinstr ................................. <"twinkle_" & tFrameList[pFrameCount]>
  [ 64] pusharglist 1 ........................... <"twinkle_" & tFrameList[pFrameCount]>
  [ 66] extcall 16 .............................. <getmemnum("twinkle_" & tFrameList[pFrameCount])>
  [ 68] setlocal 1 .............................. tImage = getmemnum("twinkle_" & tFrameList[pFrameCount])
  [ 70] getprop 5 ............................... <pSprite>
  [ 72] getlocal 1 .............................. <tImage>
  [ 74] setobjprop 21 ........................... pSprite.member = tImage
  [ 76] getprop 75 .............................. <pFrameCount>
  [ 78] pushint8 1 .............................. <1>
  [ 80] add ..................................... <pFrameCount + 1>
  [ 81] setprop 75 .............................. pFrameCount = pFrameCount + 1
  [ 83] jmp [127]
  [ 86] peek 0
  [ 88] getprop 76 .............................. <pCount>
  [ 90] pushint8 18 ............................. <18>
  [ 92] eq ...................................... <pCount = 18>
  [ 93] eq
  [ 94] jmpifz [110] ............................ (case) (pCount = 18):
  [ 97] getprop 5 ............................... <pSprite>
  [ 99] pushcons 0 .............................. <"twinkle_0">
  [101] pusharglist 1 ........................... <"twinkle_0">
  [103] extcall 16 .............................. <getmemnum("twinkle_0")>
  [105] setobjprop 21 ........................... pSprite.member = getmemnum("twinkle_0")
  [107] jmp [127]
  [110] peek 0
  [112] getprop 76 .............................. <pCount>
  [114] getprop 74 .............................. <pRandom>
  [116] eq ...................................... <pCount = pRandom>
  [117] eq
  [118] jmpifz [127] ............................ (case) (pCount = pRandom):
  [121] getparam 0 .............................. <me>
  [123] pusharglistnoret 1 ...................... <me>
  [125] objcall 1 ............................... me.reset()
  [127] pop 1 ................................... end case
  [129] ret
end
