property pSprite, pRandom, pFrameCount, pCount, pAdd

on define me, tsprite
  [  0] getparam 1 .............................. <tsprite>
  [  2] setprop 4 ............................... pSprite = tsprite
  [  4] getparam 0 .............................. <me>
  [  6] pusharglistnoret 1 ...................... <me>
  [  8] objcall 1 ............................... me.reset()
  [ 10] pushint8 1 .............................. <1>
  [ 12] pusharglistnoret 1 ...................... <1>
  [ 14] extcall 7 ............................... return 1
  [ 16] ret
end

on reset me
  [  0] pushint8 30 ............................. <30>
  [  2] pusharglist 1 ........................... <30>
  [  4] extcall 228 ............................. <random(30)>
  [  6] setprop 257 ............................. pRandom = random(30)
  [  9] getprop 4 ............................... <pSprite>
  [ 11] pushcons 0 .............................. <"twinkle_0">
  [ 13] pusharglist 1 ........................... <"twinkle_0">
  [ 15] extcall 168 ............................. <getmemnum("twinkle_0")>
  [ 17] setobjprop 167 .......................... pSprite.member = getmemnum("twinkle_0")
  [ 19] pushint8 1 .............................. <1>
  [ 21] setprop 253 ............................. pFrameCount = 1
  [ 23] pushzero ................................ <0>
  [ 24] setprop 258 ............................. pCount = 0
  [ 27] pushint8 15 ............................. <15>
  [ 29] setprop 259 ............................. pAdd = 15
  [ 32] getprop 4 ............................... <pSprite>
  [ 34] pusharglist 1 ........................... <pSprite>
  [ 36] extcall 260 ............................. <sprite(pSprite)>
  [ 39] getprop 258 ............................. <pCount>
  [ 42] setobjprop 171 .......................... sprite(pSprite).blend = pCount
  [ 44] ret
end

on update me
  [  0] getprop 258 ............................. <pCount>
  [  3] getprop 259 ............................. <pAdd>
  [  6] add ..................................... <pCount + pAdd>
  [  7] setprop 258 ............................. pCount = pCount + pAdd
  [ 10] getprop 257 ............................. <pRandom>
  [ 13] pushint8 1 .............................. <1>
  [ 15] eq ...................................... <pRandom = 1>
  [ 16] jmpifz [101] ............................ if pRandom = 1 then / else
  [ 19] pushint8 1 .............................. <1>
  [ 21] peek 0 .................................. case 1 of
  [ 23] getprop 258 ............................. <pCount>
  [ 26] pushzero ................................ <0>
  [ 27] gteq .................................... <pCount >= 0>
  [ 28] getprop 258 ............................. <pCount>
  [ 31] pushint8 100 ............................ <100>
  [ 33] lteq .................................... <pCount <= 100>
  [ 34] and ..................................... <(pCount >= 0) and (pCount <= 100)>
  [ 35] eq
  [ 36] jmpifz [ 54] ............................ (case) ((pCount >= 0) and (pCount <= 100)):
  [ 39] getprop 4 ............................... <pSprite>
  [ 41] pusharglist 1 ........................... <pSprite>
  [ 43] extcall 260 ............................. <sprite(pSprite)>
  [ 46] getprop 258 ............................. <pCount>
  [ 49] setobjprop 171 .......................... sprite(pSprite).blend = pCount
  [ 51] jmp [ 96]
  [ 54] peek 0
  [ 56] getprop 258 ............................. <pCount>
  [ 59] pushint8 100 ............................ <100>
  [ 61] gt ...................................... <pCount > 100>
  [ 62] eq
  [ 63] jmpifz [ 79] ............................ (case) (pCount > 100):
  [ 66] getprop 259 ............................. <pAdd>
  [ 69] pushint8 1 .............................. <1>
  [ 71] inv ..................................... <-1>
  [ 72] mul ..................................... <pAdd * -1>
  [ 73] setprop 259 ............................. pAdd = pAdd * -1
  [ 76] jmp [ 96]
  [ 79] peek 0
  [ 81] getprop 258 ............................. <pCount>
  [ 84] pushzero ................................ <0>
  [ 85] lt ...................................... <pCount < 0>
  [ 86] eq
  [ 87] jmpifz [ 96] ............................ (case) (pCount < 0):
  [ 90] getparam 0 .............................. <me>
  [ 92] pusharglistnoret 1 ...................... <me>
  [ 94] objcall 1 ............................... me.reset()
  [ 96] pop 1 ................................... end case
  [ 98] jmp [107]
  [101] getparam 0 .............................. <me>
  [103] pusharglistnoret 1 ...................... <me>
  [105] objcall 1 ............................... me.reset()
  [107] ret
end
