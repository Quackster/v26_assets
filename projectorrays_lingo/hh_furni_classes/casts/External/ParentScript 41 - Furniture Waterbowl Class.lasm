  [ 40] pusharglist 4 ........................... <[#string: string(me.getID()), #string: "5"]>
  [ 42] pushproplist ............................ <[#string: string(me.getID()), #string: "5"]>
  [ 43] pusharglistnoret 3 ...................... <getThread(#room).getComponent().getRoomConnection(), "SETSTUFFDATA", [#string: string(me.getID()), #string: "5"]>
  [ 45] objcall 107 ............................. getThread(#room).getComponent().getRoomConnection().send("SETSTUFFDATA", [#string: string(me.getID()), #string: "5"])
  [ 47] pushint8 1 .............................. <1>
  [ 49] pusharglistnoret 1 ...................... <1>
  [ 51] extcall 9 ............................... return 1
  [ 53] ret
end
