on prepare me, tdata
  [  0] getparam 1 .............................. <tdata>
  [  2] getobjprop 60 ........................... <tdata.count>
  [  4] pushzero ................................ <0>
  [  5] eq ...................................... <tdata.count = 0>
  [  6] jmpifz [ 19] ............................ if tdata.count = 0 then
  [  9] pushsymb 596 ............................ <#extra>
  [ 12] pushcons 0 .............................. <"1">
  [ 14] pusharglist 2 ........................... <[#extra: "1"]>
  [ 16] pushproplist ............................ <[#extra: "1"]>
  [ 17] setparam 1 .............................. tdata = [#extra: "1"]
  [ 19] getparam 0 .............................. <me>
  [ 21] getparam 1 .............................. <tdata>
  [ 23] pushsymb 596 ............................ <#extra>
  [ 26] pusharglist 2 ........................... <tdata, #extra>
  [ 28] objcall 61 .............................. <tdata[#extra]>
  [ 30] pusharglistnoret 2 ...................... <me, tdata[#extra]>
  [ 32] objcall 280 ............................. me.updateStuffdata(tdata[#extra])
  [ 35] pushint8 1 .............................. <1>
  [ 37] pusharglistnoret 1 ...................... <1>
  [ 39] extcall 9 ............................... return 1
  [ 41] ret
end

