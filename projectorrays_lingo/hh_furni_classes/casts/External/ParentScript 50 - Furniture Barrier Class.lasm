  [ 44] pushsymb 14 ............................. <#pSprList>
  [ 46] pushint8 5 .............................. <5>
  [ 48] pusharglist 3 ........................... <me, #pSprList, 5>
  [ 50] objcall 15 .............................. <me.pSprList[5]>
  [ 52] pushint8 1 .............................. <1>
  [ 54] setobjprop 138 .......................... me.pSprList[5].visible = 1
  [ 56] getprop 671 ............................. <pBlinkCounter>
  [ 59] pushint8 20 ............................. <20>
  [ 61] eq ...................................... <pBlinkCounter = 20>
  [ 62] jmpifz [ 78] ............................ if pBlinkCounter = 20 then
