  [ 23] pushint8 5 .............................. <5>
  [ 25] lt ...................................... <me.pSprList.count < 5>
  [ 26] jmpifz [ 34] ............................ if me.pSprList.count < 5 then
  [ 29] pushzero ................................ <0>
  [ 30] pusharglistnoret 1 ...................... <0>
  [ 32] extcall 9 ............................... return 0
  [ 34] getprop 671 ............................. <pBlinkCounter>
  [ 37] pushzero ................................ <0>
  [ 38] eq ...................................... <pBlinkCounter = 0>
  [ 39] jmpifz [ 56] ............................ if pBlinkCounter = 0 then
