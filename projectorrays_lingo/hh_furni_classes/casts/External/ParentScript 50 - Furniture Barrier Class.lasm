  [  6] objcall 60 .............................. <me.pSprList.count>
  [  8] pushint8 5 .............................. <5>
  [ 10] lt ...................................... <me.pSprList.count < 5>
  [ 11] jmpifz [ 19] ............................ if me.pSprList.count < 5 then
  [ 14] pushzero ................................ <0>
  [ 15] pusharglistnoret 1 ...................... <0>
  [ 17] extcall 9 ............................... return 0
  [ 19] pushzero ................................ <0>
  [ 20] setprop 671 ............................. pBlinkCounter = 0
  [ 23] getparam 1 .............................. <tValue>
  [ 25] setprop 287 ............................. pState = tValue
  [ 28] getparam 0 .............................. <me>
  [ 30] pushsymb 14 ............................. <#pSprList>
  [ 32] pushint8 5 .............................. <5>
  [ 34] pusharglist 3 ........................... <me, #pSprList, 5>
  [ 36] objcall 15 .............................. <me.pSprList[5]>
  [ 38] getprop 287 ............................. <pState>
  [ 41] pushcons 0 .............................. <"1">
  [ 43] eq ...................................... <pState = "1">
  [ 44] setobjprop 138 .......................... me.pSprList[5].visible = pState = "1"
  [ 46] pushint8 1 .............................. <1>
  [ 48] pusharglistnoret 1 ...................... <1>
  [ 50] extcall 9 ............................... return 1
