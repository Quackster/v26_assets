property pState, pBlinkCounter

on prepare me, tdata
  [  0] getparam 0 .............................. <me>
  [  2] getparam 1 .............................. <tdata>
  [  4] pushsymb 315 ............................ <#stuffdata>
  [  7] pusharglist 2 ........................... <tdata, #stuffdata>
  [  9] objcall 61 .............................. <tdata[#stuffdata]>
  [ 11] pusharglistnoret 2 ...................... <me, tdata[#stuffdata]>
