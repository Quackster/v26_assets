on select me
  [  0] pusharglist 0 ........................... <>
  [  2] thebuiltin 318 .......................... <the doubleClick>
  [  5] jmpifz [ 74] ............................ if the doubleClick then
  [  8] getprop 287 ............................. <pState>
  [ 11] peek 0 .................................. case pState of
  [ 13] pushcons 0 .............................. <"1">
  [ 15] eq
  [ 16] jmpifz [ 27] ............................ (case) "1":
  [ 19] pushcons 1 .............................. <"0">
  [ 21] setprop 287 ............................. pState = "0"
  [ 24] jmp [ 32] ............................... (case) otherwise:
  [ 27] pushcons 0 .............................. <"1">
  [ 29] setprop 287 ............................. pState = "1"
  [ 32] pop 1 ................................... end case
  [ 34] pushsymb 4 .............................. <#room>
  [ 36] pusharglist 1 ........................... <#room>
  [ 38] extcall 5 ............................... <getThread(#room)>
  [ 40] pusharglist 1 ........................... <getThread(#room)>
  [ 42] objcall 6 ............................... <getThread(#room).getComponent()>
  [ 44] pusharglist 1 ........................... <getThread(#room).getComponent()>
  [ 46] objcall 106 ............................. <getThread(#room).getComponent().getRoomConnection()>
  [ 48] pushcons 2 .............................. <"SETSTUFFDATA">
  [ 50] pushsymb 146 ............................ <#string>
  [ 52] getparam 0 .............................. <me>
  [ 54] pusharglist 1 ........................... <me>
  [ 56] objcall 7 ............................... <me.getID()>
  [ 58] pusharglist 1 ........................... <me.getID()>
  [ 60] extcall 146 ............................. <string(me.getID())>
  [ 62] pushsymb 146 ............................ <#string>
  [ 64] getprop 287 ............................. <pState>
