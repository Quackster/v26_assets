on construct me
  [  0] getparam 0 .............................. <me>
  [  2] pushint8 1 .............................. <1>
  [  4] pusharglist 2 ........................... <me, 1>
  [  6] objcall 5 ............................... <me.regMsgList(1)>
  [  8] pusharglistnoret 1 ...................... <me.regMsgList(1)>
  [ 10] extcall 6 ............................... return me.regMsgList(1)
  [ 12] ret
end

on deconstruct me
  [  0] getparam 0 .............................. <me>
  [  2] pushzero ................................ <0>
  [  3] pusharglist 2 ........................... <me, 0>
  [  5] objcall 5 ............................... <me.regMsgList(0)>
  [  7] pusharglistnoret 1 ...................... <me.regMsgList(0)>
  [  9] extcall 6 ............................... return me.regMsgList(0)
  [ 11] ret
end

on handle_ok me, tMsg
  [  0] getparam 1 .............................. <tMsg>
