on constructSpriteManager
  [  0] pushsymb 330 ............................ <#sprite_manager>
  [  3] pushcons 0 .............................. <"sprite.manager.class">
  [  5] pusharglist 1 ........................... <"sprite.manager.class">
  [  7] extcall 242 ............................. <getClassVariable("sprite.manager.class")>
  [  9] pusharglist 2 ........................... <#sprite_manager, getClassVariable("sprite.manager.class")>
  [ 11] extcall 182 ............................. <createManager(#sprite_manager, getClassVariable("sprite.manager.class"))>
  [ 13] pusharglistnoret 1 ...................... <createManager(#sprite_manager, getClassVariable("sprite.manager.class"))>
  [ 15] extcall 11 .............................. return createManager(#sprite_manager, getClassVariable("sprite.manager.class"))
  [ 17] ret
end

on deconstructSpriteManager
  [  0] pushsymb 330 ............................ <#sprite_manager>
  [  3] pusharglist 1 ........................... <#sprite_manager>
  [  5] extcall 183 ............................. <removeManager(#sprite_manager)>
  [  7] pusharglistnoret 1 ...................... <removeManager(#sprite_manager)>
  [  9] extcall 11 .............................. return removeManager(#sprite_manager)
  [ 11] ret
end

on getSpriteManager
  [  0] pusharglist 0 ........................... <>
  [  2] extcall 176 ............................. <getObjectManager()>
  [  4] setlocal 0 .............................. tMgr = getObjectManager()
  [  6] getlocal 0 .............................. <tMgr>
  [  8] pushsymb 330 ............................ <#sprite_manager>
  [ 11] pusharglist 2 ........................... <tMgr, #sprite_manager>
  [ 13] objcall 185 ............................. <tMgr.managerExists(#sprite_manager)>
  [ 15] not ..................................... <not tMgr.managerExists(#sprite_manager)>
  [ 16] jmpifz [ 27] ............................ if not tMgr.managerExists(#sprite_manager) then
  [ 19] pusharglist 0 ........................... <>
  [ 21] localcall 0 ............................. <constructSpriteManager()>
  [ 23] pusharglistnoret 1 ...................... <constructSpriteManager()>
  [ 25] extcall 11 .............................. return constructSpriteManager()
  [ 27] getlocal 0 .............................. <tMgr>
  [ 29] pushsymb 330 ............................ <#sprite_manager>
  [ 32] pusharglist 2 ........................... <tMgr, #sprite_manager>
  [ 34] objcall 184 ............................. <tMgr.getManager(#sprite_manager)>
  [ 36] pusharglistnoret 1 ...................... <tMgr.getManager(#sprite_manager)>
  [ 38] extcall 11 .............................. return tMgr.getManager(#sprite_manager)
  [ 40] ret
end

on reserveSprite tClientID
  [  0] pusharglist 0 ........................... <>
  [  2] localcall 2 ............................. <getSpriteManager()>
  [  4] getparam 0 .............................. <tClientID>
  [  6] pusharglist 2 ........................... <getSpriteManager(), tClientID>
  [  8] objcall 325 ............................. <getSpriteManager().reserveSprite(tClientID)>
  [ 11] pusharglistnoret 1 ...................... <getSpriteManager().reserveSprite(tClientID)>
  [ 13] extcall 11 .............................. return getSpriteManager().reserveSprite(tClientID)
  [ 15] ret
end

