  [  0] getprop 1157 ............................ <pLastEventData>
  [  3] pushsymb 1184 ........................... <#title>
  [  6] getparam 1 .............................. <tTitle>
  [  8] pusharglistnoret 3 ...................... <pLastEventData, #title, tTitle>
  [ 10] objcall 23 .............................. pLastEventData[#title] = tTitle
  [ 12] getprop 1157 ............................ <pLastEventData>
  [ 15] pushsymb 119 ............................ <#sprite>
  [ 17] getparam 2 .............................. <tSprID>
  [ 19] pusharglistnoret 3 ...................... <pLastEventData, #sprite, tSprID>
  [ 21] objcall 23 .............................. pLastEventData[#sprite] = tSprID
  [ 23] getprop 1157 ............................ <pLastEventData>
  [ 26] pushsymb 1185 ........................... <#Event>
  [ 29] getparam 3 .............................. <tEvent>
  [ 31] pusharglistnoret 3 ...................... <pLastEventData, #Event, tEvent>
  [ 33] objcall 23 .............................. pLastEventData[#Event] = tEvent
  [ 35] ret
end

on getLastEvent me
  [  0] getprop 1157 ............................ <pLastEventData>
  [  3] pushsymb 1184 ........................... <#title>
  [  6] pusharglist 2 ........................... <pLastEventData, #title>
  [  8] objcall 29 .............................. <pLastEventData[#title]>
  [ 10] pushcons 15 ............................. <"-">
  [ 12] joinstr ................................. <pLastEventData[#title] & "-">
  [ 13] getprop 1157 ............................ <pLastEventData>
  [ 16] pushsymb 119 ............................ <#sprite>
  [ 18] pusharglist 2 ........................... <pLastEventData, #sprite>
  [ 20] objcall 29 .............................. <pLastEventData[#sprite]>
  [ 22] joinstr ................................. <pLastEventData[#title] & "-" & pLastEventData[#sprite]>
  [ 23] pushcons 15 ............................. <"-">
  [ 25] joinstr ................................. <pLastEventData[#title] & "-" & pLastEventData[#sprite] & "-">
  [ 26] getprop 1157 ............................ <pLastEventData>
  [ 29] pushsymb 1185 ........................... <#Event>
  [ 32] pusharglist 2 ........................... <pLastEventData, #Event>
  [ 34] objcall 29 .............................. <pLastEventData[#Event]>
  [ 36] joinstr ................................. <pLastEventData[#title] & "-" & pLastEventData[#sprite] & "-" & pLastEventData[#Event]>
  [ 37] pusharglistnoret 1 ...................... <pLastEventData[#title] & "-" & pLastEventData[#sprite] & "-" & pLastEventData[#Event]>
  [ 39] extcall 11 .............................. return pLastEventData[#title] & "-" & pLastEventData[#sprite] & "-" & pLastEventData[#Event]
  [ 41] ret
end
