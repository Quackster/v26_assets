property pSprite, pOffset, pTurnPnt, pDirection, pmodel, pDelayCounter

on define me, tsprite, tCounter
  [  0] getparam 2 .............................. <tCounter>
  [  2] pushint8 2 .............................. <2>
  [  4] mod ..................................... <tCounter mod 2>
  [  5] pushint8 1 .............................. <1>
  [  7] eq ...................................... <(tCounter mod 2) = 1>
  [  8] jmpifz [ 18] ............................ if (tCounter mod 2) = 1 then / else
  [ 11] pushsymb 16 ............................. <#left>
  [ 13] setlocal 0 .............................. tDirection = #left
  [ 15] jmp [ 22]
  [ 18] pushsymb 80 ............................. <#right>
  [ 20] setlocal 0 .............................. tDirection = #right
  [ 22] getparam 1 .............................. <tsprite>
  [ 24] setprop 3 ............................... pSprite = tsprite
  [ 26] pushzero ................................ <0>
  [ 27] pushzero ................................ <0>
  [ 28] pusharglist 2 ........................... <[0, 0]>
  [ 30] pushlist ................................ <[0, 0]>
  [ 31] setprop 4 ............................... pOffset = [0, 0]
  [ 33] getlocal 0 .............................. <tDirection>
  [ 35] setprop 5 ............................... pDirection = tDirection
  [ 37] getparam 0 .............................. <me>
  [ 39] pusharglistnoret 1 ...................... <me>
  [ 41] objcall 1 ............................... me.reset()
  [ 43] pushint8 1 .............................. <1>
  [ 45] pusharglistnoret 1 ...................... <1>
  [ 47] extcall 6 ............................... return 1
  [ 49] ret
end

on reset me
  [  0] pushint16 200 ........................... <200>
  [  3] pusharglist 1 ........................... <200>
  [  5] extcall 10 .............................. <random(200)>
  [  7] setprop 248 ............................. pDelayCounter = random(200)
  [  9] pushcons 0 .............................. <"car1">
  [ 11] pushcons 1 .............................. <"car2">
  [ 13] pushcons 2 .............................. <"bus1">
  [ 15] pusharglist 3 ........................... <["car1", "car2", "bus1"]>
  [ 17] pushlist ................................ <["car1", "car2", "bus1"]>
  [ 18] pushint8 3 .............................. <3>
  [ 20] pusharglist 1 ........................... <3>
  [ 22] extcall 10 .............................. <random(3)>
  [ 24] pusharglist 2 ........................... <["car1", "car2", "bus1"], random(3)>
  [ 26] objcall 12 .............................. <["car1", "car2", "bus1"][random(3)]>
  [ 28] setprop 11 .............................. pmodel = ["car1", "car2", "bus1"][random(3)]
  [ 30] getprop 3 ............................... <pSprite>
  [ 32] getprop 11 .............................. <pmodel>
  [ 34] pushcons 3 .............................. <"_1">
  [ 36] joinstr ................................. <pmodel & "_1">
  [ 37] pusharglist 1 ........................... <pmodel & "_1">
  [ 39] extcall 13 .............................. <getmemnum(pmodel & "_1")>
  [ 41] setobjprop 14 ........................... pSprite.castNum = getmemnum(pmodel & "_1")
  [ 43] pushint16 464 ........................... <464>
  [ 46] setprop 15 .............................. pTurnPnt = 464
  [ 48] getprop 5 ............................... <pDirection>
  [ 50] pushsymb 16 ............................. <#left>
  [ 52] eq ...................................... <pDirection = #left>
  [ 53] jmpifz [ 89] ............................ if pDirection = #left then / else
  [ 56] getprop 3 ............................... <pSprite>
  [ 58] pushzero ................................ <0>
  [ 59] setobjprop 17 ........................... pSprite.flipH = 0
  [ 61] getprop 3 ............................... <pSprite>
  [ 63] pushint16 794 ........................... <794>
  [ 66] pushint16 496 ........................... <496>
  [ 69] pusharglist 2 ........................... <794, 496>
  [ 71] extcall 18 .............................. <point(794, 496)>
  [ 73] setobjprop 19 ........................... pSprite.loc = point(794, 496)
  [ 75] pushint8 2 .............................. <2>
  [ 77] inv ..................................... <-2>
  [ 78] pushint8 1 .............................. <1>
  [ 80] inv ..................................... <-1>
  [ 81] pusharglist 2 ........................... <[-2, -1]>
  [ 83] pushlist ................................ <[-2, -1]>
  [ 84] setprop 4 ............................... pOffset = [-2, -1]
  [ 86] jmp [119]
  [ 89] getprop 3 ............................... <pSprite>
  [ 91] pushint8 1 .............................. <1>
  [ 93] setobjprop 17 ........................... pSprite.flipH = 1
  [ 95] getprop 3 ............................... <pSprite>
  [ 97] pushint16 160 ........................... <160>
  [100] pushint16 500 ........................... <500>
  [103] pusharglist 2 ........................... <160, 500>
  [105] extcall 18 .............................. <point(160, 500)>
  [107] setobjprop 19 ........................... pSprite.loc = point(160, 500)
  [109] pushint8 2 .............................. <2>
  [111] pushint8 1 .............................. <1>
  [113] inv ..................................... <-1>
  [114] pusharglist 2 ........................... <[2, -1]>
  [116] pushlist ................................ <[2, -1]>
  [117] setprop 4 ............................... pOffset = [2, -1]
  [119] getprop 3 ............................... <pSprite>
  [121] getprop 3 ............................... <pSprite>
  [123] getchainedprop 20 ....................... <pSprite.member>
  [125] getobjprop 21 ........................... <pSprite.member.width>
  [127] setobjprop 21 ........................... pSprite.width = pSprite.member.width
  [129] getprop 3 ............................... <pSprite>
  [131] getprop 3 ............................... <pSprite>
  [133] getchainedprop 20 ....................... <pSprite.member>
  [135] getobjprop 22 ........................... <pSprite.member.height>
  [137] setobjprop 22 ........................... pSprite.height = pSprite.member.height
  [139] getprop 3 ............................... <pSprite>
  [141] pushint8 41 ............................. <41>
  [143] setobjprop 234 .......................... pSprite.ink = 41
  [145] getprop 3 ............................... <pSprite>
  [147] pushint16 150 ........................... <150>
  [150] pusharglist 1 ........................... <150>
  [152] extcall 10 .............................. <random(150)>
  [154] pushint8 20 ............................. <20>
  [156] add ..................................... <random(150) + 20>
  [157] setobjprop 246 .......................... pSprite.backColor = random(150) + 20
  [159] ret
end

on update me
  [  0] getprop 248 ............................. <pDelayCounter>
  [  2] pushzero ................................ <0>
  [  3] gt ...................................... <pDelayCounter > 0>
  [  4] jmpifz [ 20] ............................ if pDelayCounter > 0 then
  [  7] getprop 248 ............................. <pDelayCounter>
  [  9] pushint8 1 .............................. <1>
  [ 11] sub ..................................... <pDelayCounter - 1>
  [ 12] setprop 248 ............................. pDelayCounter = pDelayCounter - 1
  [ 14] pushint8 1 .............................. <1>
  [ 16] pusharglistnoret 1 ...................... <1>
  [ 18] extcall 6 ............................... return 1
  [ 20] getprop 3 ............................... <pSprite>
  [ 22] getprop 3 ............................... <pSprite>
  [ 24] getobjprop 19 ........................... <pSprite.loc>
  [ 26] getprop 4 ............................... <pOffset>
  [ 28] add ..................................... <pSprite.loc + pOffset>
  [ 29] setobjprop 19 ........................... pSprite.loc = pSprite.loc + pOffset
  [ 31] getprop 3 ............................... <pSprite>
  [ 33] getobjprop 24 ........................... <pSprite.locH>
  [ 35] getprop 15 .............................. <pTurnPnt>
  [ 37] eq ...................................... <pSprite.locH = pTurnPnt>
  [ 38] jmpifz [ 71] ............................ if pSprite.locH = pTurnPnt then
  [ 41] getprop 4 ............................... <pOffset>
  [ 43] pushint8 2 .............................. <2>
  [ 45] getprop 4 ............................... <pOffset>
  [ 47] pushint8 2 .............................. <2>
  [ 49] pusharglist 2 ........................... <pOffset, 2>
  [ 51] objcall 12 .............................. <pOffset[2]>
  [ 53] inv ..................................... <-pOffset[2]>
  [ 54] pusharglistnoret 3 ...................... <pOffset, 2, -pOffset[2]>
  [ 56] objcall 25 .............................. pOffset[2] = -pOffset[2]
  [ 58] getprop 3 ............................... <pSprite>
  [ 60] getprop 11 .............................. <pmodel>
  [ 62] pushcons 4 .............................. <"_2">
  [ 64] joinstr ................................. <pmodel & "_2">
  [ 65] pusharglist 1 ........................... <pmodel & "_2">
  [ 67] extcall 13 .............................. <getmemnum(pmodel & "_2")>
  [ 69] setobjprop 14 ........................... pSprite.castNum = getmemnum(pmodel & "_2")
  [ 71] getprop 3 ............................... <pSprite>
  [ 73] getobjprop 26 ........................... <pSprite.locV>
  [ 75] pushint16 510 ........................... <510>
  [ 78] gt ...................................... <pSprite.locV > 510>
  [ 79] jmpifz [ 92] ............................ if pSprite.locV > 510 then
  [ 82] getparam 0 .............................. <me>
  [ 84] pusharglist 1 ........................... <me>
  [ 86] objcall 1 ............................... <me.reset()>
  [ 88] pusharglistnoret 1 ...................... <me.reset()>
  [ 90] extcall 6 ............................... return me.reset()
  [ 92] ret
end
