on construct me
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglistnoret 1 ...................... <1>
  [  4] extcall 35 .............................. return 1
  [  6] ret
end

on deconstruct me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglistnoret 1 ...................... <me>
  [  4] objcall 545 ............................. me.removeControllingAvatar()
  [  7] pushint8 1 .............................. <1>
  [  9] pusharglistnoret 1 ...................... <1>
  [ 11] extcall 35 .............................. return 1
  [ 13] ret
end

on removeControllingAvatar me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglist 1 ........................... <me>
  [  4] objcall 228 ............................. <me.getGameSystem()>
  [  6] getparam 0 .............................. <me>
  [  8] pushsymb 308 ............................ <#pGameObjectSyncValues>
  [ 11] pushsymb 46 ............................. <#human_id>
  [ 13] pusharglist 3 ........................... <me, #pGameObjectSyncValues, #human_id>
  [ 15] objcall 139 ............................. <me.pGameObjectSyncValues[#human_id]>
  [ 17] pushsymb 546 ............................ <#reset_player>
  [ 20] pusharglist 3 ........................... <me.getGameSystem(), me.pGameObjectSyncValues[#human_id], #reset_player>
  [ 22] objcall 66 .............................. <me.getGameSystem().executeGameObjectEvent(me.pGameObjectSyncValues[#human_id], #reset_player)>
  [ 24] pusharglistnoret 1 ...................... <me.getGameSystem().executeGameObjectEvent(me.pGameObjectSyncValues[#human_id], #reset_player)>
  [ 26] extcall 35 .............................. return me.getGameSystem().executeGameObjectEvent(me.pGameObjectSyncValues[#human_id], #reset_player)
  [ 28] ret
end
