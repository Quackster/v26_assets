  [ 64] extcall 122 ............................. <member(getmemnum("hit" & pAnimFrame))>
  [ 66] setobjprop 122 .......................... pSprite.member = member(getmemnum("hit" & pAnimFrame))
  [ 68] getprop 714 ............................. <pAnimFrame>
  [ 71] pushint8 1 .............................. <1>
  [ 73] add ..................................... <pAnimFrame + 1>
  [ 74] setprop 714 ............................. pAnimFrame = pAnimFrame + 1
  [ 77] pushint8 1 .............................. <1>
  [ 79] pusharglistnoret 1 ...................... <1>
  [ 81] extcall 35 .............................. return 1
  [ 83] ret
end

on createSprites me, tScreenLoc, tlocz
  [  0] pushcons 1 .............................. <"snowball_hit_">
  [  2] pusharglist 0 ........................... <>
  [  4] extcall 715 ............................. <getUniqueID()>
  [  7] joinstr ................................. <"snowball_hit_" & getUniqueID()>
  [  8] pusharglist 1 ........................... <"snowball_hit_" & getUniqueID()>
