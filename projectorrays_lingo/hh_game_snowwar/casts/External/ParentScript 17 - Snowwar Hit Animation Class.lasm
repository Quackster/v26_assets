property pActive, pSprite, pStep, pAnimFrame

on construct me
  [  0] pushint8 1 .............................. <1>
  [  2] setprop 580 ............................. pActive = 1
  [  5] pushint8 1 .............................. <1>
  [  7] pusharglistnoret 1 ...................... <1>
  [  9] extcall 35 .............................. return 1
  [ 11] ret
end

on deconstruct me
  [  0] pushzero ................................ <0>
  [  1] setprop 580 ............................. pActive = 0
  [  4] getparam 0 .............................. <me>
  [  6] pusharglistnoret 1 ...................... <me>
  [  8] objcall 668 ............................. me.removeSprites()
  [ 11] pushint8 1 .............................. <1>
  [ 13] pusharglistnoret 1 ...................... <1>
  [ 15] extcall 35 .............................. return 1
  [ 17] ret
end

on define me, tScreenLoc, tlocz
  [  0] pushzero ................................ <0>
  [  1] setprop 713 ............................. pStep = 0
  [  4] pushint8 1 .............................. <1>
  [  6] setprop 714 ............................. pAnimFrame = 1
  [  9] getparam 0 .............................. <me>
  [ 11] getparam 1 .............................. <tScreenLoc>
  [ 13] getparam 2 .............................. <tlocz>
  [ 15] pusharglistnoret 3 ...................... <me, tScreenLoc, tlocz>
  [ 17] objcall 667 ............................. me.createSprites(tScreenLoc, tlocz)
  [ 20] pushint8 1 .............................. <1>
  [ 22] pusharglistnoret 1 ...................... <1>
  [ 24] extcall 35 .............................. return 1
  [ 26] ret
end

on update me
  [  0] getprop 580 ............................. <pActive>
  [  3] not ..................................... <not pActive>
  [  4] jmpifz [ 12] ............................ if not pActive then
  [  7] pushzero ................................ <0>
  [  8] pusharglistnoret 1 ...................... <0>
  [ 10] extcall 35 .............................. return 0
  [ 12] getprop 713 ............................. <pStep>
  [ 15] not ..................................... <not pStep>
  [ 16] setprop 713 ............................. pStep = not pStep
  [ 19] getprop 713 ............................. <pStep>
  [ 22] jmpifz [ 31] ............................ if pStep then
  [ 25] pushint8 1 .............................. <1>
  [ 27] pusharglistnoret 1 ...................... <1>
  [ 29] extcall 35 .............................. return 1
  [ 31] getprop 714 ............................. <pAnimFrame>
  [ 34] pushint8 4 .............................. <4>
  [ 36] eq ...................................... <pAnimFrame = 4>
  [ 37] jmpifz [ 50] ............................ if pAnimFrame = 4 then
  [ 40] getparam 0 .............................. <me>
  [ 42] pusharglist 1 ........................... <me>
  [ 44] objcall 1 ............................... <me.deconstruct()>
  [ 46] pusharglistnoret 1 ...................... <me.deconstruct()>
  [ 48] extcall 35 .............................. return me.deconstruct()
  [ 50] getprop 116 ............................. <pSprite>
  [ 52] pushcons 0 .............................. <"hit">
  [ 54] getprop 714 ............................. <pAnimFrame>
  [ 57] joinstr ................................. <"hit" & pAnimFrame>
  [ 58] pusharglist 1 ........................... <"hit" & pAnimFrame>
