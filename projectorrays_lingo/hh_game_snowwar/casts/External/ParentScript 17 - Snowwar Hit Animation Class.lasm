  [ 14] extcall 76 .............................. <sprite(reserveSprite("snowball_hit_" & getUniqueID()))>
  [ 16] setprop 116 ............................. pSprite = sprite(reserveSprite("snowball_hit_" & getUniqueID()))
  [ 18] getprop 116 ............................. <pSprite>
  [ 20] pushcons 2 .............................. <"hit1">
  [ 22] pusharglist 1 ........................... <"hit1">
  [ 24] extcall 141 ............................. <getmemnum("hit1")>
  [ 26] pusharglist 1 ........................... <getmemnum("hit1")>
