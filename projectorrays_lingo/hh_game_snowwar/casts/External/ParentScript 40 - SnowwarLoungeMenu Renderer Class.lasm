  [  7] getparam 1 .............................. <tTime>
  [  9] pushint8 60 ............................. <60>
  [ 11] mod ..................................... <tTime mod 60>
  [ 12] setlocal 1 .............................. tSec = tTime mod 60
  [ 14] getlocal 1 .............................. <tSec>
  [ 16] pushint8 10 ............................. <10>
  [ 18] lt ...................................... <tSec < 10>
  [ 19] jmpifz [ 29] ............................ if tSec < 10 then
  [ 22] pushcons 51 ............................. <"0">
  [ 24] getlocal 1 .............................. <tSec>
  [ 26] joinstr ................................. <"0" & tSec>
  [ 27] setlocal 1 .............................. tSec = "0" & tSec
  [ 29] getlocal 0 .............................. <tMin>
  [ 31] pushcons 52 ............................. <":">
  [ 33] joinstr ................................. <tMin & ":">
  [ 34] getlocal 1 .............................. <tSec>
  [ 36] joinstr ................................. <tMin & ":" & tSec>
  [ 37] pusharglistnoret 1 ...................... <tMin & ":" & tSec>
  [ 39] extcall 35 .............................. return tMin & ":" & tSec
  [ 41] ret
end
